<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customer Satisfaction Survey — Sailor Force USA</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
  :root {
    --navy: #0f1e3c;
    --navy-mid: #1a2f58;
    --gold: #c9a84c;
    --gold-light: #e8c96d;
    --cream: #faf8f4;
    --text: #1a1a2e;
    --muted: #6b7280;
    --border: #e2ddd5;
    --white: #ffffff;
    --success: #10b981;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── HERO HEADER ── */
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #243a6e 100%);
    padding: 48px 24px 56px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.12) 0%, transparent 60%);
  }

  .hero-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .logo-mark {
    width: 44px; height: 44px;
    border: 2px solid var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .logo-mark svg { width: 22px; height: 22px; fill: var(--gold); }

  .hero-brand {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    color: var(--gold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 5vw, 40px);
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 12px;
    position: relative;
  }

  .hero p {
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    font-weight: 300;
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.6;
    position: relative;
  }

  .gold-line {
    width: 48px; height: 2px;
    background: var(--gold);
    margin: 20px auto;
  }

  /* ── FORM WRAPPER ── */
  .form-wrap {
    max-width: 680px;
    margin: -24px auto 60px;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  /* ── CARDS ── */
  .card {
    background: var(--white);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 16px;
    box-shadow: 0 2px 20px rgba(15,30,60,0.07);
    border: 1px solid rgba(226,221,213,0.6);
    opacity: 0;
    transform: translateY(20px);
    animation: slideUp 0.5s ease forwards;
  }

  .card:nth-child(1) { animation-delay: 0.1s; }
  .card:nth-child(2) { animation-delay: 0.2s; }
  .card:nth-child(3) { animation-delay: 0.3s; }
  .card:nth-child(4) { animation-delay: 0.4s; }
  .card:nth-child(5) { animation-delay: 0.5s; }
  .card:nth-child(6) { animation-delay: 0.6s; }

  @keyframes slideUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .card-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
  }

  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 19px;
    color: var(--navy);
    margin-bottom: 20px;
  }

  /* ── ANON TOGGLE ── */
  .anon-toggle {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #f0f4ff;
    border: 1.5px solid #c7d2fe;
    border-radius: 12px;
    padding: 14px 18px;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }

  .anon-toggle:hover { background: #e8eeff; }
  .anon-toggle.active { background: #eef2ff; border-color: var(--navy-mid); }

  .toggle-switch {
    width: 44px; height: 24px;
    background: #d1d5db;
    border-radius: 99px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.25s;
  }

  .toggle-switch::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    transition: transform 0.25s;
  }

  .toggle-switch.on { background: var(--navy-mid); }
  .toggle-switch.on::after { transform: translateX(20px); }

  .anon-text strong { display: block; font-size: 13px; color: var(--navy); }
  .anon-text span { font-size: 12px; color: var(--muted); }

  /* ── CUSTOMER FIELDS ── */
  #customerFields {
    margin-top: 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    transition: opacity 0.3s, transform 0.3s;
  }

  #customerFields.hidden {
    opacity: 0.2;
    pointer-events: none;
    filter: blur(1px);
  }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field.full { grid-column: 1/-1; }

  .field label {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .field input, .field select {
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: var(--cream);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    appearance: none;
  }

  .field input:focus, .field select:focus {
    border-color: var(--navy-mid);
    box-shadow: 0 0 0 3px rgba(26,47,88,0.08);
    background: var(--white);
  }

  /* ── STAR RATING ── */
  .rating-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .rating-row:last-child { border-bottom: none; padding-bottom: 0; }
  .rating-row:first-child { padding-top: 0; }

  .rating-question {
    font-size: 14px;
    color: var(--text);
    flex: 1;
    padding-right: 20px;
    line-height: 1.4;
  }

  .stars {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .stars input { display: none; }

  .stars label {
    font-size: 24px;
    cursor: pointer;
    color: #d1d5db;
    transition: color 0.15s, transform 0.15s;
    line-height: 1;
  }

  .stars label:hover,
  .stars label:hover ~ label { color: #d1d5db; }

  .stars:hover label { color: var(--gold-light); }

  .stars label:hover ~ label { color: #d1d5db !important; }

  .stars input:checked ~ label { color: #d1d5db; }
  .stars input:checked + label,
  .stars input:checked ~ label:not(input:checked ~ label ~ label) { color: var(--gold); }

  /* Trick: stars go right-to-left visually */
  .stars { flex-direction: row-reverse; }
  .stars label:hover,
  .stars label:hover ~ label { color: var(--gold-light) !important; }

  /* ── RECOMMEND PILLS ── */
  .pill-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .pill-group input { display: none; }

  .pill-group label {
    padding: 10px 22px;
    border: 1.5px solid var(--border);
    border-radius: 99px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
    background: var(--cream);
  }

  .pill-group input:checked + label {
    border-color: var(--navy);
    background: var(--navy);
    color: var(--white);
  }

  .pill-group label:hover { border-color: var(--navy-mid); color: var(--navy); }

  /* ── TEXTAREA ── */
  .field textarea {
    padding: 12px 14px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: var(--cream);
    resize: vertical;
    min-height: 80px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    line-height: 1.6;
  }

  .field textarea:focus {
    border-color: var(--navy-mid);
    box-shadow: 0 0 0 3px rgba(26,47,88,0.08);
    background: var(--white);
  }

  /* ── SUBMIT BUTTON ── */
  .submit-wrap {
    text-align: center;
    padding: 8px 0 0;
  }

  .submit-btn {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    color: var(--white);
    border: none;
    padding: 16px 48px;
    border-radius: 99px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: all 0.25s;
    box-shadow: 0 4px 24px rgba(15,30,60,0.25);
    position: relative;
    overflow: hidden;
  }

  .submit-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.15) 0%, transparent 60%);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(15,30,60,0.32);
  }

  .submit-btn:active { transform: translateY(0); }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .submit-note {
    font-size: 11px;
    color: var(--muted);
    margin-top: 10px;
  }

  /* ── SUCCESS STATE ── */
  #successScreen {
    display: none;
    text-align: center;
    padding: 60px 32px;
    background: var(--white);
    border-radius: 16px;
    box-shadow: 0 2px 20px rgba(15,30,60,0.07);
  }

  .success-icon {
    width: 72px; height: 72px;
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
    font-size: 32px;
  }

  #successScreen h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    color: var(--navy);
    margin-bottom: 10px;
  }

  #successScreen p { color: var(--muted); font-size: 14px; line-height: 1.7; }

  /* ── SERVICE INFO ── */
  .service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 4px;
  }

  /* ── FOOTER ── */
  .footer {
    text-align: center;
    padding: 0 0 40px;
    font-size: 11px;
    color: var(--muted);
  }

  /* Mobile */
  @media (max-width: 520px) {
    #customerFields { grid-template-columns: 1fr; }
    .service-grid { grid-template-columns: 1fr; }
    .rating-row { flex-direction: column; align-items: flex-start; gap: 10px; }
    .stars { flex-direction: row-reverse; }
    .card { padding: 22px; }
  }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-logo">
    <div class="logo-mark">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 17l4-8 5 6 3-4 6 6H3z"/>
        <path d="M12 3 L12 8" stroke="#c9a84c" stroke-width="1.5" fill="none"/>
        <path d="M8 5 L16 5 L12 12 Z" fill="#c9a84c" opacity="0.7"/>
      </svg>
