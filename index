</div>

<!-- FORM -->
<div class="form-wrap">
  <form id="surveyForm">

    <!-- CARD 1: ANONYMOUS -->
    <div class="card">
      <div class="card-label">Privacy</div>
      <div class="card-title">Your Information</div>

      <div class="anon-toggle" id="anonToggle" onclick="toggleAnon()">
        <div class="toggle-switch" id="toggleSwitch"></div>
        <div class="anon-text">
          <strong>Submit Anonymously</strong>
          <span>Your name and contact info won't be shared</span>
        </div>
      </div>

      <div id="customerFields">
        <div class="field"><label>Full Name</label><input type="text" id="customerName" placeholder="John Smith"></div>
        <div class="field"><label>Email</label><input type="email" id="email" placeholder="john@example.com"></div>
        <div class="field"><label>Phone</label><input type="tel" id="phone" placeholder="+1 (000) 000-0000"></div>
