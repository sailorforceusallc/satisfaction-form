    <!-- CARD 3: RATINGS -->
    <div class="card">
      <div class="card-label">Rate Your Experience</div>
      <div class="card-title">Service Quality</div>

      <div class="rating-row">
        <div class="rating-question">Overall satisfaction with the service</div>
