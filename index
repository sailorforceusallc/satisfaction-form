<script>
// ── CONFIG ──────────────────────────────────────────────
const EMAILJS_PUBLIC_KEY  = 'YOUR_EMAILJS_PUBLIC_KEY';   // ← Step 3
const EMAILJS_SERVICE_ID  = 'YOUR_SERVICE_ID';            // ← Step 3
const EMAILJS_TEMPLATE_ID = 'YOUR_TEMPLATE_ID';           // ← Step 3
const SHEETS_WEBHOOK_URL  = 'YOUR_APPS_SCRIPT_URL';       // ← Step 5
// ────────────────────────────────────────────────────────

emailjs.init(EMAILJS_PUBLIC_KEY);

let isAnon = false;

function toggleAnon() {
  isAnon = !isAnon;
  document.getElementById('toggleSwitch').classList.toggle('on', isAnon);
  document.getElementById('anonToggle').classList.toggle('active', isAnon);
  document.getElementById('customerFields').classList.toggle('hidden', isAnon);
}

function getR(name) {
  const s = document.querySelector(`input[name="${name}"]:checked`);
  return s ? s.value : '—';
}

function stars(val) {
  if (val === '—') return 'N/A';
  return '★'.repeat(Number(val)) + '☆'.repeat(5 - Number(val)) + ` (${val}/5)`;
}

async function buildPDFBase64(data) {
  const { jsPDF } = window.jspdf;
  const pdf = new jsPDF('p', 'mm', 'letter');
  const W = 180;
  let y = 15;

  const navy = [15, 30, 60];
  const gold = [201, 168, 76];

  const hdr = (title) => {
    pdf.setFillColor(...navy); pdf.rect(15, y, W, 6, 'F');
    pdf.setFontSize(8); pdf.setFont('helvetica','bold'); pdf.setTextColor(255,255,255);
    pdf.text(title, 17, y+4.2); pdf.setTextColor(0,0,0); y += 9;
  };

  // Header
  pdf.setFontSize(15); pdf.setFont('helvetica','bold'); pdf.setTextColor(...navy);
  pdf.text('SAILOR FORCE USA LLC', 15, y); y += 6;
  pdf.setFontSize(7.5); pdf.setFont('helvetica','normal'); pdf.setTextColor(80,80,80);
  pdf.text('2719 Hollywood Blvd #A-2119  ·  Hollywood, FL 33020  ·  +1 (754) 465-3952  ·  sales@sailorforce.com', 15, y);
  y += 4;
  pdf.setDrawColor(...gold); pdf.setLineWidth(1); pdf.line(15, y, 195, y); y += 7;

  pdf.setFontSize(14); pdf.setFont('helvetica','bold'); pdf.setTextColor(...navy);
  pdf.text('CUSTOMER SATISFACTION SURVEY', 105, y, { align:'center' }); y += 5;
  pdf.setFontSize(8); pdf.setFont('helvetica','normal'); pdf.setTextColor(120,120,120);
  pdf.text(`Submitted: ${new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'})}`, 105, y, { align:'center' });
  y += 9;

  if (data.anonymous) {
    pdf.setFillColor(230,235,248); pdf.rect(15, y, W, 8, 'F');
    pdf.setDrawColor(...navy); pdf.rect(15, y, W, 8, 'S');
    pdf.setFontSize(8); pdf.setFont('helvetica','bold'); pdf.setTextColor(...navy);
    pdf.text('ANONYMOUS SUBMISSION', 105, y+5.5, {align:'center'});
    pdf.setTextColor(0,0,0); y += 13;
  } else {
    hdr('CUSTOMER INFORMATION');
    pdf.setFontSize(8); pdf.setFont('helvetica','normal');
    pdf.text(`Name:    ${data.name}`, 17, y); pdf.text(`Email:  ${data.email}`, 105, y); y += 5;
    pdf.text(`Phone:   ${data.phone}`, 17, y); pdf.text(`Vessel: ${data.vessel}`, 105, y); y += 9;
  }

  hdr('SERVICE DETAILS');
  pdf.setFontSize(8); pdf.setFont('helvetica','normal');
  pdf.text(`Service Date:  ${data.serviceDate || '—'}`, 17, y);
  pdf.text(`Service Type:  ${data.serviceType || '—'}`, 105, y); y += 5;
  pdf.text(`Technician:    ${data.tech || '—'}`, 17, y); y += 9;

  hdr('SERVICE RATINGS');
  const qs = [
    ['Overall satisfaction', data.q1],
    ['Quality of work', data.q2],
    ['Professionalism', data.q3],
    ['Timeliness', data.q4],
    ['Value for money', data.q5],
  ];
  pdf.setFillColor(232,236,243); pdf.rect(15, y, W, 5, 'F');
  pdf.setFontSize(7); pdf.setFont('helvetica','bold'); pdf.setTextColor(...navy);
  pdf.text('Category', 17, y+3.5);
  pdf.text('Rating', 150, y+3.5, {align:'center'});
  pdf.setTextColor(0,0,0); y += 6;

  qs.forEach((q, i) => {
    pdf.setFillColor(i%2===0?255:248, i%2===0?255:249, i%2===0?255:250);
    pdf.rect(15, y, W, 5.5, 'F');
    pdf.setFont('helvetica','normal'); pdf.setFontSize(8);
    pdf.text(q[0], 17, y+3.8);
    const val = q[1] === '—' ? 'N/A' : `${'★'.repeat(Number(q[1]))}${'☆'.repeat(5-Number(q[1]))} (${q[1]}/5)`;
    pdf.setFont('helvetica','bold'); pdf.setTextColor(q[1] !== '—' ? gold[0] : 100, q[1] !== '—' ? gold[1] : 100, q[1] !== '—' ? gold[2] : 100);
    pdf.text(val, 150, y+3.8, {align:'center'});
    pdf.setTextColor(0,0,0); y += 6;
  });
  y += 5;

  hdr('RECOMMENDATION');
  pdf.setFontSize(8); pdf.setFont('helvetica','normal');
  pdf.text(`Would recommend Sailor Force: ${data.recommend}`, 17, y); y += 9;

  hdr('COMMENTS & SUGGESTIONS');
  pdf.setFont('helvetica','bold'); pdf.setFontSize(8);
  pdf.text('What did we do well?', 17, y); y += 4;
  pdf.setFont('helvetica','normal');
  pdf.setDrawColor(200,200,200); pdf.rect(15, y, W, 14, 'S');
  if (data.feedbackPos) {
    const lines = pdf.splitTextToSize(data.feedbackPos, W-4);
    pdf.text(lines.slice(0,4), 17, y+3);
  }
  y += 17;
  pdf.setFont('helvetica','bold');
  pdf.text('What could we improve?', 17, y); y += 4;
  pdf.setFont('helvetica','normal');
  pdf.rect(15, y, W, 14, 'S');
  if (data.feedbackImp) {
    const lines2 = pdf.splitTextToSize(data.feedbackImp, W-4);
    pdf.text(lines2.slice(0,4), 17, y+3);
  }
  y += 20;

  pdf.setFontSize(7); pdf.setTextColor(160,160,160);
  pdf.text('This survey response is confidential and used solely to improve Sailor Force USA LLC services.', 105, y, {align:'center'});

  return pdf.output('datauristring').split(',')[1];
}

async function submitSurvey() {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending…';

  const data = {
    anonymous:   isAnon,
    name:        isAnon ? 'Anonymous' : (document.getElementById('customerName').value || '—'),
    email:       isAnon ? 'Anonymous' : (document.getElementById('email').value || '—'),
    phone:       isAnon ? 'Anonymous' : (document.getElementById('phone').value || '—'),
    vessel:      isAnon ? 'Anonymous' : (document.getElementById('vesselName').value || '—'),
    serviceDate: document.getElementById('serviceDate').value || '—',
    serviceType: document.getElementById('serviceType').value || '—',
    tech:        document.getElementById('techName').value || '—',
    q1: getR('q1'), q2: getR('q2'), q3: getR('q3'), q4: getR('q4'), q5: getR('q5'),
    recommend:   getR('recommend'),
    feedbackPos: document.getElementById('feedbackPos').value || '—',
    feedbackImp: document.getElementById('feedbackImp').value || '—',
    submittedAt: new Date().toISOString(),
  };

  try {
    // 1. Send to Google Sheets
    await fetch(SHEETS_WEBHOOK_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    // 2. Build PDF and send email via EmailJS
    const pdfB64 = await buildPDFBase64(data);

    const avg = [data.q1,data.q2,data.q3,data.q4,data.q5]
      .filter(v => v !== '—').map(Number);
    const avgScore = avg.length ? (avg.reduce((a,b)=>a+b,0)/avg.length).toFixed(1) : 'N/A';

    await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
      to_email:    'ernesto@sailorforce.com',
      from_name:   data.name,
      customer:    data.anonymous ? 'Anonymous' : `${data.name} (${data.email})`,
      vessel:      data.vessel,
      service_type: data.serviceType,
      service_date: data.serviceDate,
      technician:  data.tech,
      q1: stars(data.q1), q2: stars(data.q2), q3: stars(data.q3),
      q4: stars(data.q4), q5: stars(data.q5),
      avg_score:   avgScore,
      recommend:   data.recommend,
      feedback_pos: data.feedbackPos,
      feedback_imp: data.feedbackImp,
      submitted_at: new Date().toLocaleString('en-US'),
      pdf_attached: pdfB64,
    });

    // Show success
    document.getElementById('surveyForm').style.display = 'none';
    document.getElementById('successScreen').style.display = 'block';

  } catch (err) {
    console.error(err);
    btn.disabled = false;
    btn.textContent = 'Submit Feedback';
    alert('Something went wrong. Please try again or contact us directly at sales@sailorforce.com');
  }
}
</script>
