      </div>

      <div class="rating-row">
        <div class="rating-question">Quality of the work performed</div>
        <div class="stars">
          <input type="radio" name="q2" id="q2-5" value="5"><label for="q2-5">★</label>
          <input type="radio" name="q2" id="q2-4" value="4"><label for="q2-4">★</label>
          <input type="radio" name="q2" id="q2-3" value="3"><label for="q2-3">★</label>
          <input type="radio" name="q2" id="q2-2" value="2"><label for="q2-2">★</label>
          <input type="radio" name="q2" id="q2-1" value="1"><label for="q2-1">★</label>
        </div>
      </div>

      <div class="rating-row">
        <div class="rating-question">Professionalism of the technician</div>
        <div class="stars">
          <input type="radio" name="q3" id="q3-5" value="5"><label for="q3-5">★</label>
          <input type="radio" name="q3" id="q3-4" value="4"><label for="q3-4">★</label>
          <input type="radio" name="q3" id="q3-3" value="3"><label for="q3-3">★</label>
          <input type="radio" name="q3" id="q3-2" value="2"><label for="q3-2">★</label>
          <input type="radio" name="q3" id="q3-1" value="1"><label for="q3-1">★</label>
